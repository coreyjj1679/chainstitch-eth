# --- Mode ---------------------------------------------------------------
# local (default): single user, no login — clone and run.
# team: SIWE (wallet) login, invite teammates by address. Requires the
#       three variables below it. See README → Self-hosting.
APP_MODE=local

# Required in team mode ----------------------------------------------------
# Comma-separated wallet addresses that get the owner role on sign-in.
OWNER_WALLETS=
# Session signing secret. Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=
# The exact URL users open in the browser (scheme + host + port). The SIWE
# login message is domain-bound to this value.
APP_URL=http://localhost:3000

# Optional -------------------------------------------------------------------
# Enables WalletConnect (QR / mobile wallets) in RainbowKit.
# Get one at https://cloud.walletconnect.com — injected wallets work without it.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
# Override the SQLite database location (default: data/chainstitch.db).
# CHAINSTITCH_DB_PATH=
# ABI lookup ("fetch by address" in the Contracts tab) works without any key
# via Sourcify and Blockscout; an Etherscan API key (free tier is fine, one
# key covers 60+ chains via their v2 API) adds Etherscan's much larger index.
# Server-side only — never exposed to the browser.
# ETHERSCAN_API_KEY=

# Landing page (team mode) ---------------------------------------------------
# Signed-out visitors on a team-mode instance see a landing page at "/".
# Both read server-side at request time — no rebuild needed to change them.
# "Try the live demo" button target: a project's "anyone with the link" URL.
# DEMO_SHARE_URL=
# "GitHub" header link + self-host section link on the landing page.
# GITHUB_URL=
